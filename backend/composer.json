{
    "name": "multi-hr/platform-backend",
    "description": "Custom PHP MVC backend for the Multi-HR Recruitment and Workforce Management Platform.",
    "type": "project",
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Support/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "find app public routes tests -name '*.php' -print0 | xargs -0 -n1 php -l",
        "migrate": "php bin/migrate.php",
        "seed": "php bin/seed.php",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
